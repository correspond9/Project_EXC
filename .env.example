# =============================================================================
# XChange Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values marked with <CHANGE_THIS>.
# The .env file is git-ignored. NEVER commit it.
# =============================================================================

# --- Application ---
ENVIRONMENT=development
DEBUG=true

# --- Database (PostgreSQL) ---
POSTGRES_USER=xchange
POSTGRES_PASSWORD=<CHANGE_THIS_strong_password>
POSTGRES_DB=xchange_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async driver used by FastAPI services (asyncpg)
DATABASE_URL=postgresql+asyncpg://xchange:<CHANGE_THIS_strong_password>@postgres:5432/xchange_db
# Sync driver used by Alembic migrations
DATABASE_SYNC_URL=postgresql://xchange:<CHANGE_THIS_strong_password>@postgres:5432/xchange_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- JWT Authentication ---
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<CHANGE_THIS_random_64_char_hex>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Binance API (Phase 4+: Live Mode Only) ---
# Leave blank during Phases 1-3. Set BINANCE_TESTNET=true for Phase 4 testing.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# --- Email (Phase 3+) ---
# Supported: any SMTP provider (SendGrid, AWS SES, Gmail SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com
SMTP_USE_TLS=true

# --- CORS / Frontend ---
# In development: http://localhost:3000
# In production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Frontend env vars (used by Next.js build — prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_WS_BASE_URL=ws://localhost/ws

# --- Admin Bootstrap ---
# Used ONLY on first startup to create the Super Admin account.
# Change immediately after first login.
FIRST_SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
FIRST_SUPER_ADMIN_PASSWORD=<CHANGE_THIS_strong_password>

# --- Simulation Engine ---
# Default slippage applied to simulation market orders (percentage, e.g. 0.05 = 0.05%)
SIMULATION_SLIPPAGE_PERCENT=0.05
# Default virtual USDT balance assigned to new student accounts
SIMULATION_DEFAULT_BALANCE=10000.00

# --- KYC/AML Provider (Phase 4+) ---
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_BASE_URL=
KYC_PROVIDER_WEBHOOK_SECRET=

# --- Monitoring (Phase 3+) ---
GRAFANA_ADMIN_PASSWORD=<CHANGE_THIS_strong_password>
